# Database (PostgreSQL on AWS RDS free tier)
DATABASE_URL=postgresql+asyncpg://tracker_user:password@your-rds-endpoint.region.rds.amazonaws.com:5432/tracker

# Authentication
APP_PASSWORD=your-secure-password
SECRET_KEY=generate-with: python -c "import secrets; print(secrets.token_hex(32))"

# Scraping
SCRAPE_CONCURRENCY=10
SCRAPE_DELAY_MIN=1.5
SCRAPE_DELAY_MAX=3.5
SCRAPE_RETRY_ROUNDS=3
SCRAPE_TIMEOUT=15

# Scheduler (daily auto-scrape)
SCHEDULER_ENABLED=true
DAILY_SCRAPE_HOUR=6
DAILY_SCRAPE_MINUTE=0

# Data retention
DATA_RETENTION_DAYS=90
